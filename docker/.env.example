# ── Database (env-only; required to reach the DB) ─────────────────────────────
DB_USER=ticketbot
DB_PASSWORD=changeme
DB_NAME=ticketbot

# ── Bootstrap (env-only) ──────────────────────────────────────────────────────
PORT=8080
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=changeme

# ── Credentials & settings ────────────────────────────────────────────────────
# Everything below can be managed in the admin panel (Config tab). When an env
# var here is set it takes precedence and is written back to the database on
# startup, after which it can be dropped from the environment. First boot needs
# the ConnectWise/Webex credentials present here (or pre-seeded in the DB).
ROOT_URL=https://your-domain.com

# ConnectWise PSA API
CW_PUB_KEY=
CW_PRIV_KEY=
CW_CLIENT_ID=
CW_COMPANY_ID=

# Webex bot token
WEBEX_SECRET=

# ── Optional operational settings (also in the Config tab) ────────────────────
# CW member identifier the bot writes as; used to skip its own webhooks.
# CW_BOT_MEMBER_IDENTIFIER=
# Killswitches / logging (true|false):
# ATTEMPT_WORKFLOW=true
# ATTEMPT_NOTIFY=true
# DEBUG_LOGGING=false

# ── Test/dev flags (env-only) ─────────────────────────────────────────────────
# SKIP_HOOKS=true
# MOCK_WEBEX=true

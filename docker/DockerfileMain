FROM golang:1.26 AS builder
WORKDIR /app
COPY go.mod go.sum ./
COPY vendor ./vendor

COPY . .

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -mod=vendor -o server .

FROM alpine:3.21 AS runtime-base
RUN apk add --no-cache ca-certificates

FROM runtime-base
WORKDIR /app
COPY --from=builder /app/server .

EXPOSE 8080

ENTRYPOINT ["./server"]